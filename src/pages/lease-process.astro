---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Lease Process"
  description="Learn how to rent UW Manor. Three simple steps: contact us, submit an application, sign the lease, and move in. Group rental for student housing in Seattle near UW."
  image="/images/dining-room.jpg"
>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="container">
      <h1>Lease Process</h1>
    </div>
  </div>

  <!-- INTRO -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <p class="text-center" style="font-size: 1.1rem; color: #555; margin-bottom: 2.5rem;">
        We rent UW Manor as a <strong>group rental</strong> — the entire house is leased to one group of students.
        The process is straightforward and we guide you every step of the way.
      </p>

      <!-- STEPS -->
      <ol class="steps" style="list-style: none;">

        <li class="step">
          <div class="step__number" aria-hidden="true">1</div>
          <div class="step__body">
            <h3>Contact Us &amp; Submit Your Application</h3>
            <p>
              The first step is to get in touch. Email us at
              <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a> or call
              <a href="tel:+12068582843">206-858-2843</a> to express your interest.
              We will provide you with pricing and availability details.
            </p>
            <p>
              Then, complete our <a href="/apply"><strong>online rental application</strong></a>.
              Fill it out right in your browser — no printing or scanning required.
              Submit it directly and we'll be in touch promptly.
            </p>
            <div class="mt-1">
              <a href="/apply" class="btn btn--primary">Fill Out Application Online</a>
            </div>
          </div>
        </li>

        <li class="step" style="margin-top: 2rem;">
          <div class="step__number" aria-hidden="true">2</div>
          <div class="step__body">
            <h3>Complete Lease &amp; Make Required Deposits</h3>
            <p>
              Once your group is approved to rent UW Manor, you will be required to complete a
              lease agreement and make certain deposits.
              We will walk you through this process in detail once your group has been selected.
            </p>
          </div>
        </li>

        <li class="step" style="margin-top: 2rem;">
          <div class="step__number" aria-hidden="true">3</div>
          <div class="step__body">
            <h3>Easy Move-In Process</h3>
            <p>
              On your move-in date, your keys will be waiting for you.
              We will complete a condition form with you documenting the state of your bedroom
              and the common areas — this protects you and ensures a smooth move-out experience.
            </p>
          </div>
        </li>

      </ol>
    </div>
  </section>

  <!-- PHOTO HIGHLIGHTS -->
  <section class="section section--gray">
    <div class="container">
      <h2 class="text-center">What Awaits You</h2>
      <div class="photo-grid">
        <img src="/images/dining-room.jpg" alt="UW Manor dining room" loading="lazy" />
        <img src="/images/kitchen-family-room.jpg" alt="UW Manor kitchen and family room" loading="lazy" />
        <img src="/images/backyard-turf.jpg" alt="UW Manor backyard with turf lawn" loading="lazy" />
        <img src="/images/back-decks.jpg" alt="UW Manor decks" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <h2 class="text-center">Frequently Asked Questions</h2>
      <div style="margin-top: 2rem;">

        <div style="margin-bottom: 1.75rem;">
          <h3>Is UW Manor affiliated with the University of Washington?</h3>
          <p>No. UW Manor is a privately owned property and is not owned by or affiliated with the University of Washington in any way.</p>
        </div>

        <div style="margin-bottom: 1.75rem;">
          <h3>Can I rent just one bedroom?</h3>
          <p>We rent the entire house as a group rental only. Your group would lease the whole house together. Please contact us for pricing details.</p>
        </div>

        <div style="margin-bottom: 1.75rem;">
          <h3>What is included with the rental?</h3>
          <p>
            The rent includes fully furnished common areas (living room, dining room), monthly professional cleaning of all common areas,
            year-round yard maintenance, ample parking (tandem + two garages), and access to the large private backyard with decks and patios.
          </p>
        </div>

        <div style="margin-bottom: 1.75rem;">
          <h3>What do I need to bring?</h3>
          <p>The common areas are fully furnished. The only items you need to provide are those for your own bedroom. Every bedroom has its own private lock.</p>
        </div>

        <div style="margin-bottom: 1.75rem;">
          <h3>How do I get started?</h3>
          <p>
            Email <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a> or call
            <a href="tel:+12068582843">206-858-2843</a> to inquire about pricing and availability,
            then <a href="/apply">complete our online application</a>.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="cta-strip">
    <div class="container">
      <h2>Ready to Move Forward?</h2>
      <p>Apply online today — it only takes a few minutes.</p>
      <a href="/apply" class="btn btn--white">Apply Now</a>
    </div>
  </div>

</BaseLayout>
