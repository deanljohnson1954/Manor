---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<BaseLayout
  title="Lease Process"
  description="Three simple steps to rent UW Manor: contact us, submit your application, sign the lease, and move in. Group rental student housing near the University of Washington."
  image="/images/dining-room.jpg"
>

  <div class="page-header">
    <div class="container">
      <h1>Lease Process</h1>
      <span class="page-header__sub">Three simple steps to make UW Manor your new home</span>
    </div>
  </div>

  <!-- INTRO -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 style="color:var(--uw-purple);">How It Works</h2>
          <div class="gold-bar" style="margin-left:0;"></div>
          <p>
            We rent UW Manor as a <strong>group rental</strong> — the entire house is leased to
            one group of students. The process is simple and we guide you every step of the way.
          </p>
          <p style="font-size:0.9rem; color:var(--text-mid);">
            <a href="tel:+12068582843">206-858-2843</a> &nbsp;·&nbsp;
            <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a>
          </p>
        </div>
        <div>
          <img src={`${b}/images/dining-room.jpg`} alt="UW Manor dining room"
            style="border-radius:8px; border:3px solid var(--uw-gold-light); width:100%;" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- STEPS -->
  <section class="section section--gray">
    <div class="container" style="max-width:800px;">
      <h2 class="section-heading">The Three Steps</h2>
      <div class="gold-bar"></div>
      <ol class="steps">
        <li class="step">
          <div class="step__number" aria-hidden="true">1</div>
          <div class="step__body">
            <h3>Contact Us &amp; Submit Your Application</h3>
            <p>
              Email <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a> or call
              <a href="tel:+12068582843">206-858-2843</a> to get pricing and availability.
            </p>
          </div>
        </li>
        <li class="step" style="margin-top:2rem;">
          <div class="step__number" aria-hidden="true">2</div>
          <div class="step__body">
            <h3>Complete Lease &amp; Make Required Deposits</h3>
            <p>
              Once approved, your group will complete a lease agreement and make the required deposits.
              We'll walk you through every detail once your group has been selected.
            </p>
          </div>
        </li>
        <li class="step" style="margin-top:2rem;">
          <div class="step__number" aria-hidden="true">3</div>
          <div class="step__body">
            <h3>Easy Move-In</h3>
            <p>
              On move-in day, your keys will be waiting. We'll complete a condition form documenting
              the state of your bedroom and common areas to protect everyone.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- PHOTOS -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">What Awaits You</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid">
        <img src={`${b}/images/kitchen-family-room.jpg`} alt="Kitchen and family room" loading="lazy" />
        <img src={`${b}/images/backyard-turf.jpg`}       alt="Backyard"                loading="lazy" />
        <img src={`${b}/images/back-decks.jpg`}          alt="Decks"                   loading="lazy" />
        <img src={`${b}/images/main-bathroom.jpg`}       alt="Bathroom"                loading="lazy" />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--gray">
    <div class="container" style="max-width:780px;">
      <h2 class="section-heading">Frequently Asked Questions</h2>
      <div class="gold-bar"></div>
      <div style="margin-top:2rem; display:flex; flex-direction:column; gap:1rem;">
        {[
          {q: "Is UW Manor affiliated with the University of Washington?", a: "No. UW Manor is privately owned and has no affiliation with the University of Washington."},
          {q: "Can I rent just one bedroom?", a: "We rent the entire house to one group only. Contact us for current pricing and availability."},
          {q: "What is included in the rent?", a: "Fully furnished common areas, monthly professional cleaning, year-round yard maintenance, ample parking (tandem + two garages), and the large private backyard with decks and patios."},
          {q: "What do I need to bring?", a: "Only items for your own bedroom. Common areas are fully furnished and every bedroom has its own private lock."},
        ].map(item => (
          <div style="background:#fff; padding:1.25rem 1.5rem; border-radius:6px; border-left:4px solid var(--uw-gold); box-shadow:0 1px 6px rgba(75,46,131,0.07);">
            <h3 style="color:var(--uw-purple); font-size:1rem; margin-bottom:0.35rem;">{item.q}</h3>
            <p style="margin:0; color:var(--text-mid); font-size:0.92rem;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="cta-strip">
    <div class="container">
      <h2>Ready to Move Forward?</h2>
      <p>
        <a href="tel:+12068582843" style="color:var(--uw-gold); font-weight:700;">206-858-2843</a>
        &nbsp;·&nbsp;
        <a href="mailto:uwmanor@gmail.com" style="color:var(--uw-gold); font-weight:700;">uwmanor@gmail.com</a>
      </p>
    </div>
  </div>

</BaseLayout>
