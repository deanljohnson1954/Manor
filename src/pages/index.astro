---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<BaseLayout
  title="Home"
  description="UW Manor – premium student group rental on Greek Row, just steps from the University of Washington. Fully furnished common areas, 5 bathrooms, large backyard, decks, and parking."
  image="/images/backyard2.jpg"
>

  <!-- HERO -->
  <section class="hero" aria-label="UW Manor hero">
    <img src={`${b}/images/backyard2.jpg`} alt="UW Manor backyard" class="hero__bg" fetchpriority="high" />
    <div class="hero__content">
      <div class="hero__eyebrow">Greek Row · Seattle, WA</div>
      <h1 class="hero__title">UW MANOR</h1>
      <p class="hero__subtitle">Premier Student Group Rental — One Block from Campus</p>
      <p class="hero__disclaimer">Not owned by or affiliated with the University of Washington</p>
      <div class="hero__actions">
        <a href={`${b}/about`} class="btn btn--gold">See the Property</a>
        <a href={`${b}/lease-process`} class="btn btn--outline-white">Lease Process</a>
      </div>
    </div>
  </section>

  <!-- GOLD ADDRESS STRIP -->
  <div style="background: var(--uw-gold); padding: 0.6rem 1.5rem; text-align: center;">
    <p style="margin:0; font-weight:700; color: var(--uw-purple); font-size:0.88rem; letter-spacing:0.02em;">
      5048 17th Ave. NE, Seattle, WA 98105 &nbsp;|&nbsp;
      <a href="tel:+12068582843" style="color:var(--uw-purple);">206-858-2843</a> &nbsp;|&nbsp;
      <a href="mailto:uwmanor@gmail.com" style="color:var(--uw-purple);">uwmanor@gmail.com</a>
    </p>
  </div>

  <!-- INTRO -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 style="color:var(--uw-purple);">A Home Away From Home</h2>
          <div class="gold-bar" style="margin-left:0;"></div>
          <p>
            UW Manor sits just one block from Greek Row — a ten-minute walk to the main entrance of the
            University of Washington. We rent the entire house as a <strong>group rental</strong>,
            perfect for students who want to live together in comfort.
          </p>
          <p>
            Common areas are fully furnished. All you need to bring is what's for your own bedroom.
            Every bedroom has its own lock.
          </p>
          <p style="font-size:0.9rem; color:var(--text-mid);">
            <a href="tel:+12068582843">206-858-2843</a> &nbsp;·&nbsp;
            <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a> &nbsp;·&nbsp;
            <a href="https://www.uwcourt.com" target="_blank" rel="noopener">uwcourt.com</a>
          </p>
          <a href={`${b}/about`} class="btn btn--purple" style="margin-top:0.5rem;">Explore the Property</a>
        </div>
        <div>
          <img src={`${b}/images/kitchen-family-room.jpg`} alt="UW Manor kitchen and family room"
            style="border-radius:8px; border:3px solid var(--uw-gold-light); width:100%;" />
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section section--gray">
    <div class="container">
      <h2 class="section-heading">We Handle All the Details</h2>
      <div class="gold-bar"></div>
      <div class="features">
        <div class="feature-card">
          <div class="feature-card__icon">🛋️</div>
          <h3>Fully Furnished Common Areas</h3>
          <p>Living room and dining room fully furnished and ready from day one.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card__icon">🧹</div>
          <h3>Monthly Professional Cleaning</h3>
          <p>A professional cleaner visits monthly to keep all common areas spotless.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card__icon">🌿</div>
          <h3>Yard Maintenance Included</h3>
          <p>Year-round care for the front yard and enclosed private backyard.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card__icon">🔑</div>
          <h3>Private Bedroom Locks</h3>
          <p>Every bedroom has its own lock for privacy and security.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card__icon">🚗</div>
          <h3>Ample Parking</h3>
          <p>2–3 car tandem parking plus two single-car garages.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card__icon">🛁</div>
          <h3>Five Elegant Bathrooms</h3>
          <p>A true luxury in student housing — no waiting in line.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PHOTO GRID -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">A Look Inside</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid">
        <img src={`${b}/images/backyard2.jpg`}        alt="UW Manor backyard"          loading="lazy" />
        <img src={`${b}/images/back-decks.jpg`}       alt="UW Manor back decks"        loading="lazy" />
        <img src={`${b}/images/dining-room.jpg`}      alt="UW Manor dining room"       loading="lazy" />
        <img src={`${b}/images/main-bathroom.jpg`}    alt="UW Manor main bathroom"     loading="lazy" />
        <img src={`${b}/images/back-patio.jpg`}       alt="UW Manor back patio"        loading="lazy" />
        <img src={`${b}/images/house-exterior.jpg`}   alt="UW Manor house exterior"    loading="lazy" />
      </div>
      <div class="text-center mt-2">
        <a href={`${b}/about`} class="btn btn--purple">View All Photos &amp; Amenities</a>
      </div>
    </div>
  </section>

  <!-- CTA STRIP -->
  <div class="cta-strip">
    <div class="container">
      <h2>Questions? We'd Love to Hear From You</h2>
      <p>
        <a href="tel:+12068582843" style="color:var(--uw-gold); font-weight:700;">206-858-2843</a>
        &nbsp;·&nbsp;
        <a href="mailto:uwmanor@gmail.com" style="color:var(--uw-gold); font-weight:700;">uwmanor@gmail.com</a>
      </p>
      <a href={`${b}/lease-process`} class="btn btn--gold">Learn About the Lease Process</a>
    </div>
  </div>

</BaseLayout>
