---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<BaseLayout
  title="Apply"
  description="Download the UW Manor rental application. All group members must submit a completed application along with a copy of their ID."
  image="/images/exterior-hero.jpg"
>

  <div class="page-header">
    <div class="container">
      <h1>Rental Application</h1>
      <span class="page-header__sub">5048 17th Ave. NE · Seattle, WA 98105</span>
    </div>
  </div>

  <section class="section">
    <div class="container" style="max-width:780px;">

      <!-- PROCESS BOX -->
      <div style="background:#fff; border:2px solid var(--uw-gold); border-radius:8px; padding:2rem 2.5rem; margin-bottom:2.5rem; box-shadow:0 2px 12px rgba(0,0,0,0.07);">
        <h2 style="color:var(--uw-purple); margin-bottom:0.5rem;">How to Apply</h2>
        <div class="gold-bar" style="margin-left:0;"></div>

        <ol style="margin:1rem 0 0 1.25rem; line-height:2.4; font-size:1rem;">
          <li>
            <strong>Call us first</strong> — Contact us at
            <a href="tel:+12068582843">206-858-2843</a> or
            <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a> to confirm
            the house is available for rent before submitting any application.
          </li>
          <li>
            <strong>Every group member</strong> must complete and submit a separate application form.
          </li>
          <li>
            <strong>Include a copy of your ID</strong> with each application — a Driver's License
            or Passport <em>and</em> your University of Washington Student ID.
          </li>
          <li>
            Email your completed application and ID copies to
            <a href="mailto:uwmanor@gmail.com"><strong>uwmanor@gmail.com</strong></a>.
          </li>
        </ol>
      </div>

      <!-- DOWNLOAD BUTTON -->
      <div style="text-align:center; margin-bottom:2.5rem;">
        <a href={`${b}/Student-Rental-Application.pdf`} download class="btn btn--gold"
          style="font-size:1.1rem; padding:1rem 3rem;">
          ⬇ Download Application (PDF)
        </a>
        <p style="margin-top:1rem; font-size:0.88rem; color:var(--text-light);">
          Fill it out on your computer or print and complete by hand, then email to
          <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a>.
        </p>
      </div>

      <!-- CONTACT BOX -->
      <div class="address-block" style="max-width:480px; margin:0 auto;">
        <h3>Contact Us First</h3>
        <p>Call or email to confirm availability before applying.</p>
        <p style="font-size:1.1rem; font-weight:700;">
          <a href="tel:+12068582843" style="color:#fff;">206-858-2843</a>
        </p>
        <p>
          <a href="mailto:uwmanor@gmail.com" style="color:var(--uw-gold-light);">uwmanor@gmail.com</a>
        </p>
      </div>

    </div>
  </section>

</BaseLayout>
