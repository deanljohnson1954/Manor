---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<BaseLayout
  title="About"
  description="UW Manor – just a few blocks from the University of Washington. Five bathrooms, large fenced backyard, furnished common areas, parking, and monthly cleaning."
  image="/images/exterior-hero.jpg"
>

  <div class="page-header">
    <div class="container">
      <h1>About UW Manor</h1>
      <span class="page-header__sub">5048 17th Ave. NE · Seattle, WA · A few blocks from UW Campus</span>
    </div>
  </div>

  <!-- LOCATION -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 style="color:var(--uw-purple);">Prime Location</h2>
          <div class="gold-bar" style="margin-left:0;"></div>
          <p>
            UW Manor is located at <strong>5048 17th Ave. NE, Seattle, WA 98105</strong>
            — just a few blocks from the University of Washington main campus.
            &nbsp;<a href="https://www.google.com/maps/place/5048+17th+Ave+NE,+Seattle,+WA+98105" target="_blank" rel="noopener" style="font-size:0.88rem;">→ View on Map</a>
          </p>
          <p>
            Originally a private residence, UW Manor was converted to student housing and now offers
            amenities rarely found in the area.
          </p>
          <ul style="margin:0.5rem 0 1.25rem 1.5rem; line-height:2.1;">
            <li>Large upper and lower decks</li>
            <li>Private fenced backyard with patio</li>
            <li>Five elegant bathrooms</li>
            <li>Fully furnished living and dining rooms</li>
            <li>2–3 car tandem parking + two single-car garages</li>
            <li>Monthly professional cleaning of common areas</li>
            <li>Year-round yard maintenance</li>
          </ul>
          <p style="font-size:0.9rem;">
            <a href="tel:+12068582843">206-858-2843</a> &nbsp;·&nbsp;
            <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a>
          </p>
        </div>
        <div style="display:flex; flex-direction:column; gap:1rem;">
          <img src={`${b}/images/exterior-hero.jpg`} alt="UW Manor exterior"
            style="border-radius:8px; border:3px solid var(--uw-gold-light); width:100%;" loading="lazy" />
          <div class="address-block">
            <h3>Get in Touch</h3>
            <p>5048 17th Ave. NE, Seattle, WA 98105</p>
            <p><a href="tel:+12068582843">206-858-2843</a></p>
            <p><a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a></p>
            <a href="https://www.google.com/maps/place/5048+17th+Ave+NE,+Seattle,+WA+98105"
              target="_blank" rel="noopener" class="btn btn--gold" style="margin-top:0.75rem; display:inline-block;">
              View on Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXTERIOR -->
  <section class="section section--gray">
    <div class="container">
      <h2 class="section-heading">The Property</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid">
        <img src={`${b}/images/exterior-hero.jpg`}  alt="UW Manor front exterior"  loading="lazy" />
        <img src={`${b}/images/exterior-rear.jpg`}  alt="UW Manor back exterior"   loading="lazy" />
        <img src={`${b}/images/deck-patio.jpg`}     alt="Back deck and patio"      loading="lazy" />
      </div>
    </div>
  </section>

  <!-- OUTDOOR SPACES -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">Outdoor Spaces</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid">
        <img src={`${b}/images/deck-main.jpg`}    alt="Main deck with pergola and seating" loading="lazy" />
        <img src={`${b}/images/deck-side.jpg`}    alt="Upper side deck"                    loading="lazy" />
        <img src={`${b}/images/backyard-new.jpg`} alt="Private fenced backyard"            loading="lazy" />
      </div>
    </div>
  </section>

  <!-- INTERIOR -->
  <section class="section section--gray">
    <div class="container">
      <h2 class="section-heading">Interior &amp; Common Areas</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid">
        <img src={`${b}/images/living-room-new.jpg`}  alt="Furnished living room"   loading="lazy" />
        <img src={`${b}/images/dining-room-new.jpg`}  alt="Formal dining room"      loading="lazy" />
        <img src={`${b}/images/lower-level-new.jpg`}  alt="Lower level lounge"      loading="lazy" />
      </div>
    </div>
  </section>

  <!-- BEDROOMS -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">Bedrooms</h2>
      <div class="gold-bar"></div>
      <p class="text-center" style="color:var(--text-light); max-width:580px; margin:0 auto 1.5rem;">
        Every bedroom has its own private lock. Bring only what you need for your room — common areas are fully furnished.
      </p>
      <div class="photo-grid">
        <img src={`${b}/images/bedroom-furnished.jpg`} alt="Furnished bedroom"               loading="lazy" />
        <img src={`${b}/images/bedroom-a.jpg`}         alt="Bright bedroom with two windows" loading="lazy" />
        <img src={`${b}/images/bedroom-b.jpg`}         alt="Sunny bedroom with radiator"     loading="lazy" />
        <img src={`${b}/images/bedroom-c.jpg`}         alt="Spacious bedroom with closets"   loading="lazy" />
        <img src={`${b}/images/bedroom-lower.jpg`}     alt="Lower level bedroom"             loading="lazy" />
      </div>
    </div>
  </section>

  <!-- BATHROOMS -->
  <section class="section section--gray">
    <div class="container">
      <h2 class="section-heading">Five Elegant Bathrooms</h2>
      <div class="gold-bar"></div>
      <p class="text-center" style="color:var(--text-light); max-width:580px; margin:0 auto 1.5rem;">
        A rare luxury in student housing — five beautifully appointed bathrooms means no waiting.
      </p>
      <div class="photo-grid">
        <img src={`${b}/images/bathroom-4.jpg`}   alt="Renovated bathroom with marble vanity and stylish shower" loading="lazy" />
        <img src={`${b}/images/bathroom-1.jpg`}   alt="Bathroom with marble countertop and chrome fixtures"     loading="lazy" />
        <img src={`${b}/images/bathroom-new.jpg`} alt="Bathroom with floral shower curtain and pedestal sink"   loading="lazy" />
        <img src={`${b}/images/bathroom-5.jpg`}   alt="Bright bathroom with wood vanity and large mirror"       loading="lazy" />
        <img src={`${b}/images/bathroom-6.jpg`}   alt="Bathroom with built-in shelves and patterned tile floor" loading="lazy" />
        <img src={`${b}/images/bathroom-2.jpg`}   alt="Spacious bathroom with double vanity and linen shelves"  loading="lazy" />
      </div>
    </div>
  </section>

  <!-- UW CAMPUS -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">Steps from the University of Washington</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
        <img src={`${b}/images/uw-blossoms.jpg`} alt="UW campus cherry blossoms" loading="lazy" />
        <img src={`${b}/images/uw-campus.jpg`}   alt="UW campus in spring"       loading="lazy" />
        <img src={`${b}/images/uw-library.jpg`}  alt="UW Suzzallo Library"        loading="lazy" />
      </div>
    </div>
  </section>

  <div class="cta-strip">
    <div class="container">
      <h2>Interested in Renting UW Manor?</h2>
      <p>Contact us today or fill out our online application to get started.</p>
      <a href={`${b}/apply`} class="btn btn--gold">Apply Now</a>
      &nbsp;&nbsp;
      <a href={`${b}/lease-process`} class="btn btn--outline-white">Lease Process</a>
    </div>
  </div>

</BaseLayout>
