---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/+$/, '');
---
<BaseLayout title="Application Submitted" description="Your UW Manor rental application has been submitted.">
  <div class="page-header">
    <div class="container">
      <h1>Application Submitted</h1>
    </div>
  </div>
  <section class="section">
    <div class="container" style="max-width:600px; text-align:center;">
      <p style="font-size:1.2rem; margin-bottom:1rem;">Thank you — your application has been received.</p>
      <p>Please email a copy of your <strong>UW Student ID</strong> and <strong>Driver's License or Passport</strong> to <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a> to complete your application.</p>
      <p style="margin-top:1.5rem;"><a href={`${b}/`} class="btn btn--gold">Back to Home</a></p>
    </div>
  </section>
</BaseLayout>
