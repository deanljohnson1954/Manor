---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
}

const { title, description, image = '/images/backyard2.jpg', canonicalUrl } = Astro.props;

// Normalize base: always no trailing slash  e.g. "/Manor"
const b = import.meta.env.BASE_URL.replace(/\/+$/, '');

const siteTitle = 'UW Manor | Student Housing Seattle';
const fullTitle = title === 'Home' ? siteTitle : `${title} | UW Manor`;
const siteUrl = Astro.site!.origin;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();

const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="UW Manor" />
    <meta name="keywords" content="UW Manor, student housing Seattle, University of Washington housing, group rental Seattle, Seattle student apartments, student rental near UW campus, furnished student housing Seattle, 5048 17th Ave NE Seattle, UW student house, University District rental" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="UW Manor exterior — student group rental near University of Washington, Seattle" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="UW Manor" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="UW Manor exterior — student group rental near University of Washington, Seattle" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["ApartmentComplex", "LocalBusiness"],
      "@id": "https://uwmanor.com/#business",
      "name": "UW Manor",
      "description": "Student group rental house near the University of Washington. 12 bedrooms, 5 bathrooms, furnished common areas, large backyard, decks, and parking. Up to 15 residents.",
      "url": siteUrl,
      "image": `${siteUrl}/images/exterior-hero.jpg`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "5048 17th Ave NE",
        "addressLocality": "Seattle",
        "addressRegion": "WA",
        "postalCode": "98105",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 47.6663,
        "longitude": -122.3091
      },
      "telephone": "+1-760-603-0022",
      "email": "uwmanor@gmail.com",
      "numberOfRooms": 12,
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "Private Fenced Backyard", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Monthly Professional Cleaning", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Furnished Common Areas", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Parking", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Upper and Lower Decks", "value": true}
      ],
      "containedInPlace": {
        "@type": "City",
        "name": "Seattle"
      }
    })} />
    <slot name="head" />
    <link rel="icon" type="image/svg+xml" href={`${b}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>

  <body>
    <header class="site-header" role="banner">
      <div class="container">
        <a class="site-logo" href={`${b}/`} aria-label="UW Manor – Home">
          <span class="site-logo__mark"></span>
          <span class="site-logo__text"></span>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <nav class="main-nav" id="mainNav" role="navigation" aria-label="Main navigation">
          <ul>
            <li><a href={`${b}/`}          aria-current={path === `${b}/` || path === b ? 'page' : undefined}>Home</a></li>
            <li><a href={`${b}/about`}     aria-current={path.includes('/about') ? 'page' : undefined}>About</a></li>
            <li><a href={`${b}/lease-process`} aria-current={path.includes('/lease-process') ? 'page' : undefined}>Lease Process</a></li>
            <li><a href={`${b}/apply`}     aria-current={path.includes('/apply') ? 'page' : undefined}>Apply</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content"><slot /></main>

    <footer class="site-footer" role="contentinfo">
      <div class="container">
        <div class="footer-logo">UW MANOR</div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <ul>
            <li><a href={`${b}/`}>Home</a></li>
            <li><a href={`${b}/about`}>About</a></li>
            <li><a href={`${b}/lease-process`}>Lease Process</a></li>
            <li><a href={`${b}/apply`}>Apply</a></li>
          </ul>
        </nav>
        <hr class="footer-divider" />
        <div class="footer-copy">
          <p>5048 17th Ave. NE, Seattle, WA 98105 &nbsp;|&nbsp;
            <a href="tel:+17606030022">760-603-0022</a> &nbsp;|&nbsp;
            <a href="mailto:uwmanor@gmail.com">uwmanor@gmail.com</a>
          </p>
          <p>Not owned by or affiliated with the University of Washington.</p>
          <p>&copy; {new Date().getFullYear()} UW Manor. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('navToggle');
      const nav = document.getElementById('mainNav');
      toggle?.addEventListener('click', () => {
        const isOpen = nav?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
    </script>
  </body>
</html>
