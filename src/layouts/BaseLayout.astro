---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  image = '/images/backyard2.jpg',
  canonicalUrl,
} = Astro.props;

const siteTitle = 'UW Manor | Student Housing Seattle';
const fullTitle = title === 'Home' ? siteTitle : `${title} | UW Manor`;
const siteUrl = 'https://uwmanor.com';
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const ogImage = `${siteUrl}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="UW Manor" />
    <meta name="keywords" content="UW Manor, student housing Seattle, University of Washington housing, Greek Row rental, Seattle student apartments, 5048 17th Ave NE" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="UW Manor" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Local Business Structured Data -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ApartmentComplex",
        "name": "UW Manor",
        "description": "Student group rental house on Greek Row, Seattle — a short walk to the University of Washington.",
        "url": siteUrl,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "5048 17th Ave. NE",
          "addressLocality": "Seattle",
          "addressRegion": "WA",
          "postalCode": "98105",
          "addressCountry": "US"
        },
        "telephone": "+1-206-858-2843",
        "email": "uwmanor@gmail.com",
        "amenityFeature": [
          {"@type": "LocationFeatureSpecification", "name": "Large furnished common areas"},
          {"@type": "LocationFeatureSpecification", "name": "5 bathrooms"},
          {"@type": "LocationFeatureSpecification", "name": "Upper and lower decks"},
          {"@type": "LocationFeatureSpecification", "name": "Fenced backyard with artificial turf"},
          {"@type": "LocationFeatureSpecification", "name": "2-3 car tandem parking"},
          {"@type": "LocationFeatureSpecification", "name": "Two single-car garages"},
          {"@type": "LocationFeatureSpecification", "name": "Monthly professional cleaning"},
          {"@type": "LocationFeatureSpecification", "name": "Yard maintenance included"}
        ]
      })}
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet" />

  </head>

  <body>
    <!-- ===== HEADER ===== -->
    <header class="site-header" role="banner">
      <div class="container">
        <a class="site-logo" href="/" aria-label="UW Manor – Home">UW MANOR</a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav class="main-nav" id="mainNav" role="navigation" aria-label="Main navigation">
          <ul>
            <li><a href="/" aria-current={Astro.url.pathname === '/' ? 'page' : undefined}>Home</a></li>
            <li><a href="/about" aria-current={Astro.url.pathname === '/about' ? 'page' : undefined}>About</a></li>
            <li><a href="/lease-process" aria-current={Astro.url.pathname === '/lease-process' ? 'page' : undefined}>Lease Process</a></li>
            <li><a href="/apply" aria-current={Astro.url.pathname === '/apply' ? 'page' : undefined}>Apply Now</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="site-footer" role="contentinfo">
      <div class="container">
        <nav class="footer-nav" aria-label="Footer navigation">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/lease-process">Lease Process</a></li>
            <li><a href="/apply">Apply Now</a></li>
          </ul>
        </nav>
        <hr class="footer-divider" />
        <div class="footer-copy">
          <p>5048 17th Ave. NE, Seattle, WA 98105 &nbsp;|&nbsp;
            <a href="tel:+12068582843" style="color: rgba(255,255,255,0.6)">206-858-2843</a> &nbsp;|&nbsp;
            <a href="mailto:uwmanor@gmail.com" style="color: rgba(255,255,255,0.6)">uwmanor@gmail.com</a>
          </p>
          <p>Not owned by or affiliated with the University of Washington.</p>
          <p>&copy; {new Date().getFullYear()} UW Manor. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <!-- Mobile nav script -->
    <script>
      const toggle = document.getElementById('navToggle');
      const nav = document.getElementById('mainNav');
      toggle?.addEventListener('click', () => {
        const isOpen = nav?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
    </script>
  </body>
</html>
